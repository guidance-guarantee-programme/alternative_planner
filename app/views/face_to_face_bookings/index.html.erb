<% content_for(:page_title, 'Face-to-face Bookings') %>
<div class="page-header">
  <ol class="breadcrumb">
    <li><%= link_to 'Alternative planner', root_path %></li>
    <li class="active">Face-to-face bookings</li>
  </ol>

  <h1>Face-to-face Bookings</h1>
</div>

<div class="row">
  <div class="col-md-12">
    <% if @bookings.empty? %>
      <p class="no-content t-notice">No bookings.</p>
    <% else %>
      <%= paginate @bookings %>

      <table class="table table-bordered centred-table table-striped">
        <caption><span class="sr-only">Face-to-face Bookings</span></caption>
        <thead>
          <tr class="table-header">
            <th>Reference</th>
            <th>Requested</th>
            <th>Customer name</th>
            <th>Processed</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @bookings.each do |booking| %>
            <% booking = FaceToFaceBookingDecorator.new(booking) %>
            <tr class="t-booking">
              <td>
                <%= booking.id %>
              </td>
              <td class="t-created-at">
                <%= time_ago_in_words(booking.created_at) %> ago
              </td>
              <td class="t-full-name">
                <%= booking.full_name %>
              </td>
              <td class="t-processed">
                <%= booking.processed %>
              </td>
              <td>
                <%= link_to(booking, title: 'Manage', class: 'btn btn-info t-manage') do %>
                  <span class="glyphicon glyphicon-pencil" aria-hidden="true"></span>
                  <span class="sr-only">Manage</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <%= paginate @bookings %>
    <% end %>
  </div>
</div>
